{
	"name": "obsidian-whisper-local",
	"version": "0.1.0",
	"description": "Döschl Whispert Local — Local speech-to-text for Obsidian using whisper.cpp",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"whisper",
		"whisper-cpp",
		"speech-to-text",
		"voice-input",
		"voice-to-chat",
		"local",
		"privacy",
		"no-api-key",
		"free",
		"gpu-accelerated",
		"offline"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/latein-lernen/obsidian-whisper-local.git"
	},
	"bugs": {
		"url": "https://github.com/latein-lernen/obsidian-whisper-local/issues"
	},
	"homepage": "https://github.com/latein-lernen/obsidian-whisper-local#readme",
	"author": "Döschl (latein-lernen.com)",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.8.3"
	}
}
